<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>instagram</title>
    <style>
        img{
            height: 300px;
            width: 400px;
        }
    </style>
</head>
<body>
    <h2>this is your page: <%= data.name  %></h2>
    <button>Follow</button>
    <button>Massage</button>
    <!-- <h3>Accounts that follow You: </h3> -->

    <p>

        follower: <%= data.followers  %>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;following: <%= data.following  %>
    </p>
    <hr>

    <% for(let post of data.posts) { %>
        <img src="<%= post.image%>" alt="some image" />
        <p>

        likes: <%= post.likes  %>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;comments: <%= post.comments  %>
    </p>
        <% } %>
    

     
        
</body>
</html>




